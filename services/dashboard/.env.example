# fourotwo dashboard configuration. Copy to `.env` and adjust for local dev.
# Next.js auto-loads .env / .env.local from this directory.

# URL of the running fourotwo facilitator (used by the Playground demo route).
FACILITATOR_URL=http://localhost:4001

# KYX registry URL used by server-side dashboard routes.
KYX_REGISTRY_URL=http://localhost:4002

# KYX registry URL exposed to the browser (must be NEXT_PUBLIC_*).
NEXT_PUBLIC_KYX_REGISTRY_URL=http://localhost:4002
