# fourotwo facilitator configuration. Copy to `.env` and fill in.
# NEVER commit a real .env — service account keys are secrets (NFR security).

# ---- Server ----
PORT=4001
HOST=0.0.0.0
LOG_LEVEL=info

# ---- Default chain ----
# Which adapter handles payments when the envelope network is ambiguous.
# AD-2: Casper is primary, Base is the fallback insurance path.
DEFAULT_NETWORK=casper

# ---- Casper (primary) ----
CASPER_NODE_RPC=https://rpc.testnet.casperlabs.io/rpc
CASPER_CHAIN_NAME=casper-test
# CSPR.cloud is used for on-chain reads (balances, deploy status).
CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_API_KEY=
# Deployed contract hashes (from contracts/deployed-addresses.json after M1-T2/T4).
KYX_REGISTRY_CONTRACT_HASH=
SETTLEMENT_VAULT_CONTRACT_HASH=
# Seed URef of the KyxRegistry Odra `state` dictionary (uref-<64hex>-NNN), from
# the contract's named keys. Set (with KYX_REGISTRY_CONTRACT_HASH) to enable
# on-chain trust reads; the HTTP KYX registry is the fallback.
KYX_REGISTRY_STATE_UREF=
# Algorithm of FACILITATOR_SECRET_KEY_PATH: ed25519 (01… keys) or secp256k1 (02…).
FACILITATOR_KEY_ALGORITHM=ed25519
# Gas for a record_settlement contract call, in motes (default 10 CSPR).
CASPER_SETTLEMENT_PAYMENT_MOTES=10000000000

# ---- Base (fallback) ----
BASE_RPC_URL=https://sepolia.base.org
BASE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ---- Facilitator service account ----
# Used to broadcast settlements and to sign settlement receipts.
# AD-8 / NFR: this is the facilitator's OWN key, never a developer's key.
#
# Provide the key ONE of two ways (FACILITATOR_SECRET_KEY wins if both set):
#  - FACILITATOR_SECRET_KEY: the key material directly — full PEM text, or
#    base64-of-the-PEM (recommended on PaaS like Render where multiline env
#    vars are awkward: `base64 -w0 secret_key.pem`).
#  - FACILITATOR_SECRET_KEY_PATH: path to a PEM file (handy for local dev).
FACILITATOR_SECRET_KEY=
FACILITATOR_SECRET_KEY_PATH=./keys/facilitator_secret_key.pem
# Hex-encoded ed25519 secret key used to sign settlement receipts (32 bytes).
# If unset, an ephemeral signing key is generated at boot (fine for local dev).
FACILITATOR_RECEIPT_SIGNING_KEY=

# ---- KYX Registry service (built in M3) ----
# Until M3 ships, /verify returns a trust_pending stub. Set this once the
# registry service is up to enrich verifications with live trust scores.
KYX_REGISTRY_URL=http://localhost:4002
