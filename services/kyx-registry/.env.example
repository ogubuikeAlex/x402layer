# fourotwo KYX registry configuration. Copy to `.env` and adjust for local dev.
# Loaded automatically from this directory because `npm run dev -w @fourotwo/kyx-registry`
# runs with cwd = services/kyx-registry.

# ---- Server ----
KYX_PORT=4002
KYX_HOST=0.0.0.0
LOG_LEVEL=info

# Public URL advertised in registry responses.
KYX_PUBLIC_URL=http://localhost:4002

# Path to the JSON data file (defaults to .data/kyx.json under this service).
# KYX_DATA_FILE=

# On-chain registry contract hash (optional; from contracts/deployed-addresses.json).
# KYX_REGISTRY_CONTRACT_HASH=

# ---- Storage ----
# MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net
# MONGODB_DB=fourotwo-kyx

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=abcd efgh ijkl mnop
# MAIL_FROM=fourotwo KYX <you@gmail.com>

# Comma-separated operator emails that STILL get dev_token in the API response
# even when SMTP is configured - keeps headless demo agents (Atlas) able to
# self-register without a mailbox.
# KYX_DEV_TOKEN_EMAILS=atlas-demo@fourotwo.dev

# NOTE: set KYX_PUBLIC_URL to the registry's public URL in production - it is
# the base of the magic link sent in verification emails.
