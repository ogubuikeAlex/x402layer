# Meridian RWA Data API (reference merchant)

# Port this API-doc site + paid endpoints listen on.
PORT=5100

# The live fourotwo facilitator used to verify + settle payments.
FACILITATOR_URL=https://fourotwo-facilitator.onrender.com

# The merchant's on-chain payout account — the agent's real CSPR transfer lands here.
# Provide a real casper-test account hash (account-hash-<64hex> or bare 64hex) to
# use a STABLE payout account you control. If left blank/invalid, Meridian mints an
# ephemeral merchant wallet at startup so real transfers still have a valid target.
# Real native transfers need the tagged Casper public key (01... or 02...), not
# only an account hash.
MERCHANT_RECIPIENT=

# Which browser origins may call the paid API (the Atlas agent app origin, or * for demo).
CORS_ORIGIN=*

# Explorer used for cspr.live links.
CASPER_EXPLORER_URL=https://testnet.cspr.live
