# Atlas agent app (reference agent-sdk consumer)

# Port the Atlas UI + backend listen on.
PORT=5200

# The agent's FUNDED casper-test wallet. MUST be an ed25519 key — fourotwo signs
# with ed25519 only (a secp256k1 / "EC PRIVATE KEY" wallet key will NOT work).
# Provide it ONE of these ways (checked in this order):
#
#   1) Path to the secret_key.pem your Casper wallet exports (easiest):
AGENT_SECRET_KEY_PATH=
#
#   2) The PEM inline — paste the file contents, or its base64 (good for hosting):
AGENT_SECRET_KEY_PEM=
#
#   3) The raw 32-byte ed25519 seed as hex (advanced):
AGENT_PRIVATE_KEY_HEX=
#
# Leave all three empty to auto-generate an ephemeral (unfunded) key for a dry run.
# Inspect / fund a key:  node demos/agent-app/keyinfo.mjs <path-to-secret_key.pem>

# The paid API the agent buys from (the Meridian provider demo).
MERCHANT_URL=http://localhost:5100

# CSPR.cloud (for reading the wallet balance). Key optional on testnet.
CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_API_KEY=

# Casper network for the REAL settlement transfer (funds actually move on-chain).
CASPER_CHAIN_NAME=casper-test
CASPER_NODE_RPC=https://rpc.testnet.casperlabs.io/rpc
CASPER_NODE_RPC_FALLBACKS=
CASPER_EXPLORER_URL=https://testnet.cspr.live

# KYX registry the agent self-registers with on startup (so it appears on /agents).
KYX_REGISTRY_URL=https://x402layer-kyx-registry.onrender.com
AGENT_OPERATOR_EMAIL=atlas-demo@fourotwo.dev
AGENT_NAME=Atlas Research Agent
# Set to false to skip auto-registration.
AGENT_AUTO_REGISTER=true
