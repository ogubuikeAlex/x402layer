{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "FACILITATOR_URL",
        "KYX_REGISTRY_URL",
        "NEXT_PUBLIC_KYX_REGISTRY_URL",
        "CSPR_CLOUD_API_URL",
        "DEMO_RECIPIENT_ACCOUNT_HASH",
        "FOUROTWO_PRIVATE_KEY",
        "FOUROTWO_AGENT_DID"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    }
  }
}
