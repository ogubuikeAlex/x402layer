{
  "name": "@fourotwo/agent-sdk",
  "version": "1.0.0",
  "private": false,
  "description": "fourotwo TypeScript SDK for automatic x402 payment handling",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fourotwo/types": "^0.1.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
